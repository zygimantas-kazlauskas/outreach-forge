# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit it.

ANTHROPIC_API_KEY=your-key-here

# Optional debug/test flags. Leave unset for normal operation.

# LLM_LOG_FULL=1 — log full system prompt, user message, and parsed response
# to backend/logs/llm_calls.jsonl (default: metadata only).
#LLM_LOG_FULL=1

# RUN_E2E=1 — enable the paid end-to-end orchestrator test
# (tests/test_orchestrator_e2e.py). Makes real API calls.
#RUN_E2E=1

# RUN_SMOKE=1 — enable the paid per-agent smoke tests
# (tests/test_agents_smoke.py). Makes real API calls.
#RUN_SMOKE=1
