# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit it.

ANTHROPIC_API_KEY=your-key-here

# Optional debug/test flags. Leave unset for normal operation.

# LLM_LOG_FULL=1 — log full system prompt, user message, and parsed response
# to backend/logs/llm_calls.jsonl (default: metadata only).
#LLM_LOG_FULL=1

# RUN_E2E=1 — enable the paid end-to-end orchestrator test
# (tests/test_orchestrator_e2e.py). Makes real API calls.
#RUN_E2E=1

# RUN_SMOKE=1 — enable the paid per-agent smoke tests
# (tests/test_agents_smoke.py). Makes real API calls.
#RUN_SMOKE=1

# --- Email sending (Block 6, Resend) -----------------------------------------
# Real sends require EVERY layer below to pass simultaneously; see
# docs/sending-safety.md for the full model and go-live steps.

# SEND_MODE — "dry_run" is the default, including when unset or typo'd:
# no network call ever happens, the would-be send is logged to
# backend/logs/send_log.jsonl and the row is marked send_status='dry_run'.
# Only the exact value "live" permits real sends.
#SEND_MODE=dry_run

# RESEND_API_KEY — Resend API key. Only read when SEND_MODE=live.
#RESEND_API_KEY=your-resend-key-here

# SEND_FROM — verified sender identity, e.g. "Name <you@yourdomain.com>".
# Required for live sends; the domain must be verified in Resend.
#SEND_FROM=

# RECIPIENT_ALLOWLIST — comma-separated addresses. When set, live sends to
# any address NOT on the list are refused. Keep this pinned to your own
# addresses while testing deliverability.
#RECIPIENT_ALLOWLIST=you@yourdomain.com,you@gmail.com

# SEND_DAILY_LIMIT — max REAL sends per UTC calendar day, counted from the
# DB (default 20). Enforces warmup discipline structurally.
#SEND_DAILY_LIMIT=20
